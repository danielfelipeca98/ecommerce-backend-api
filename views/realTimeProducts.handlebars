<h1>Productos en tiempo real</h1>

<form id="productForm">
    <input type="text" id="title" placeholder="Titulo" required>
    <input type="text" id="description" placeholder="Descripcion" required>
    <input type="text" id="code" placeholder="Codigo" required>
    <input type="number" id="price" placeholder="Precio" required>
    <input type="number" id="stock" placeholder="Stock disponible" required>
    <input type="text" id="category" placeholder="Categoria" required>
    <button type="submit">Agregar Producto</button>
</form>

<hr>

<h3>Eliminar por ID (manual)</h3>
<form id="deleteForm">
    <input type="text" id="deleteId" placeholder="ID del producto a eliminar" required>
    <button type="submit">Eliminar</button>
</form>

<hr>

<h3>Lista de productos</h3>
<div id="productList">
    <ul id="product-List">
        {{#each products}}
        <li>
            <span style="font-size:0.8em; color:gray;">ID: {{this._id}}</span><br>
            <strong>{{this.title}}</strong> - ${{this.price}}
            ({{this.category}}) - Stock: {{this.stock}} - Código: {{this.code}}
            <button onclick="deleteProduct('{{this._id}}')" style="margin-left:10px; background-color:#dc3545; color:white; border:none; padding:4px 8px; border-radius:4px; cursor:pointer;">
                Eliminar
            </button>
        </li>
        {{else}}
        <li>No hay productos disponibles.</li>
        {{/each}}
    </ul>
</div>

<script src="/socket.io/socket.io.js"></script>
<script src="/js/realTime.js"></script>
<script src="/js/mensajes.js"></script>