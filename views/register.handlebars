<h2>Registro de Usuario</h2>
<form id="registerForm">
    <input type="email" id="email" name="email" placeholder="Ingrese su correo" required>
    <input type="password" id="password" name="password" placeholder="Ingrese contraseña" required>
    <input type="password" id="confirmPassword" name="confirmPassword" placeholder=" confirme contaseña" required>
    <div id="mensaje-error"></div>
    <button type="submit">Registrarse</button>

</form>
<a href="/login">¡ya tienes cuenta? Inicia sesion</a>

<script src="/js/register.js"></script>